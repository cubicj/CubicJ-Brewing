{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2022",
    "allowJs": true,
    "strict": true,
    "moduleResolution": "node",
    "isolatedModules": true,
    "lib": ["DOM", "ES2022"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
